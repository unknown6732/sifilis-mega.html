<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sífilis - Mega Apresentação | Trabalho Escolar</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: #0a0a0a;
            overflow: hidden;
            height: 100vh;
        }

        .presentation {
            width: 100%;
            height: 100vh;
            position: relative;
            background: radial-gradient(circle at 20% 30%, #0d1b2a, #0a0a0a);
        }

        /* Efeito de partículas no fundo */
        .presentation::before {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(rgba(244, 162, 97, 0.08) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }

        .slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.6s;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-y: auto;
        }

        .slide.active {
            opacity: 1;
            visibility: visible;
        }

        .slide-content {
            max-width: 1300px;
            width: 88%;
            margin: 0 auto;
            padding: 2rem 2.5rem;
            background: rgba(13, 27, 42, 0.85);
            backdrop-filter: blur(12px);
            border-radius: 2.5rem;
            animation: fadeInUp 0.6s ease;
            border: 1px solid rgba(244, 162, 97, 0.2);
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h1 {
            font-size: 4.5rem;
            font-weight: 900;
            background: linear-gradient(135deg, #f4a261 0%, #e76f51 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 1rem;
            text-align: center;
            letter-spacing: -0.02em;
        }

        h2 {
            font-size: 2.2rem;
            font-weight: 700;
            color: #f4a261;
            margin-bottom: 1.5rem;
            display: inline-block;
            border-bottom: 4px solid #e76f51;
            padding-bottom: 8px;
        }

        h3 {
            font-size: 1.5rem;
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 1rem;
        }

        .subtitle {
            font-size: 1.2rem;
            color: #cbd5e0;
            text-align: center;
            margin-bottom: 2rem;
        }

        .row {
            display: flex;
            gap: 2rem;
            align-items: center;
            justify-content: center;
            flex-wrap: wrap;
        }

        .col {
            flex: 1;
            min-width: 250px;
        }

        .texto {
            font-size: 1.05rem;
            line-height: 1.6;
            color: #e2e8f0;
        }

        .texto p {
            margin-bottom: 1rem;
        }

        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1.5rem;
            margin-top: 1rem;
        }

        .card {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 1.2rem;
            padding: 1.5rem;
            text-align: center;
            transition: all 0.3s;
            border: 1px solid rgba(244, 162, 97, 0.1);
        }

        .card:hover {
            transform: translateY(-5px);
            background: rgba(244, 162, 97, 0.1);
            border-color: rgba(244, 162, 97, 0.3);
        }

        .card-icon {
            font-size: 2.5rem;
            margin-bottom: 0.8rem;
        }

        .card h4 {
            font-size: 1.3rem;
            color: #f4a261;
            margin-bottom: 0.5rem;
        }

        .card p {
            font-size: 0.9rem;
            color: #cbd5e0;
        }

        .stats {
            display: flex;
            justify-content: center;
            gap: 2rem;
            flex-wrap: wrap;
            margin: 2rem 0;
        }

        .stat {
            background: linear-gradient(135deg, rgba(244, 162, 97, 0.15), rgba(231, 111, 81, 0.1));
            border-radius: 1.5rem;
            padding: 1.5rem;
            text-align: center;
            min-width: 170px;
            border: 1px solid rgba(244, 162, 97, 0.2);
        }

        .stat i {
            font-size: 2.5rem;
            color: #f4a261;
            margin-bottom: 0.5rem;
        }

        .stat .numero {
            font-size: 2rem;
            font-weight: 800;
            color: white;
        }

        .stat .label {
            font-size: 0.85rem;
            color: #94a3b8;
        }

        .tabela-mitos {
            width: 100%;
            border-collapse: collapse;
            margin: 1rem 0;
        }

        .tabela-mitos th, .tabela-mitos td {
            padding: 0.8rem;
            text-align: left;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .tabela-mitos th {
            background: rgba(244, 162, 97, 0.15);
            color: #f4a261;
            font-weight: 600;
        }

        .mito { color: #e76f51; }
        .verdade { color: #2a9d8f; }

        .quiz-container {
            background: rgba(0,0,0,0.3);
            border-radius: 1.2rem;
            padding: 1.2rem;
            margin-top: 1rem;
        }

        .quiz-pergunta {
            font-size: 1.2rem;
            font-weight: 600;
            color: #f4a261;
            margin-bottom: 0.8rem;
        }

        .quiz-opcao {
            background: rgba(255,255,255,0.05);
            padding: 0.7rem;
            margin: 0.4rem 0;
            border-radius: 0.6rem;
            cursor: pointer;
            transition: 0.2s;
            color: #e2e8f0;
        }

        .quiz-opcao:hover {
            background: rgba(244, 162, 97, 0.3);
        }

        .quiz-resposta {
            margin-top: 0.8rem;
            padding: 0.7rem;
            border-radius: 0.6rem;
            display: none;
        }

        .quiz-resposta.correto {
            background: rgba(42, 157, 143, 0.3);
            color: #2a9d8f;
            display: block;
        }

        .quiz-resposta.errado {
            background: rgba(231, 111, 81, 0.3);
            color: #e76f51;
            display: block;
        }

        .prevencao-lista {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1rem;
            margin: 1.5rem 0;
        }

        .prevencao-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            background: rgba(255, 255, 255, 0.04);
            padding: 1rem;
            border-radius: 1rem;
        }

        .prevencao-item i {
            font-size: 1.6rem;
            color: #f4a261;
        }

        .faq-item {
            background: rgba(255,255,255,0.03);
            border-radius: 1rem;
            padding: 1rem;
            margin-bottom: 1rem;
        }

        .faq-pergunta {
            font-weight: 700;
            color: #f4a261;
            margin-bottom: 0.5rem;
        }

        .faq-resposta {
            color: #cbd5e0;
            font-size: 0.95rem;
        }

        .linha-tempo {
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            margin: 2rem 0;
        }

        .tempo-item {
            text-align: center;
            flex: 1;
            min-width: 100px;
            padding: 1rem;
        }

        .tempo-ano {
            font-size: 1.3rem;
            font-weight: 800;
            color: #f4a261;
        }

        .tempo-evento {
            font-size: 0.85rem;
            color: #cbd5e0;
        }

        .passo-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            background: rgba(244, 162, 97, 0.1);
            padding: 0.8rem;
            margin: 0.6rem 0;
            border-radius: 1rem;
        }

        .passo-numero {
            width: 36px;
            height: 36px;
            background: #f4a261;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: #0a0a0a;
        }

        .depoimento {
            background: linear-gradient(135deg, rgba(244, 162, 97, 0.1), rgba(231, 111, 81, 0.05));
            border-radius: 1rem;
            padding: 1.2rem;
            margin: 1rem;
            font-style: italic;
            border-left: 4px solid #f4a261;
        }

        .glossario-item {
            display: flex;
            gap: 1rem;
            background: rgba(255,255,255,0.03);
            padding: 0.7rem;
            margin: 0.5rem 0;
            border-radius: 0.8rem;
        }

        .glossario-termo {
            font-weight: 700;
            color: #f4a261;
            min-width: 120px;
        }

        .btn-pdf {
            background: linear-gradient(135deg, #f4a261, #e76f51);
            color: white;
            border: none;
            padding: 12px 28px;
            border-radius: 40px;
            cursor: pointer;
            font-weight: bold;
            margin-top: 1rem;
            transition: 0.3s;
        }

        .btn-pdf:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 20px rgba(244, 162, 97, 0.4);
        }

        .ranking-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            background: rgba(255,255,255,0.03);
            padding: 0.8rem;
            margin: 0.5rem 0;
            border-radius: 0.8rem;
        }

        .ranking-pos {
            font-size: 1.5rem;
            font-weight: 800;
            color: #f4a261;
            width: 50px;
        }

        .nav {
            position: fixed;
            bottom: 25px;
            left: 0;
            right: 0;
            display: flex;
            justify-content: center;
            gap: 1rem;
            z-index: 100;
        }

        .nav button {
            background: rgba(244, 162, 97, 0.9);
            border: none;
            width: 55px;
            height: 55px;
            border-radius: 50%;
            font-size: 1.5rem;
            cursor: pointer;
            transition: 0.3s;
            color: #0a0a0a;
            font-weight: bold;
            backdrop-filter: blur(4px);
        }

        .nav button:hover {
            background: #f4a261;
            transform: scale(1.1);
            box-shadow: 0 0 20px rgba(244, 162, 97, 0.5);
        }

        .indicadores {
            position: fixed;
            bottom: 25px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 0.6rem;
            z-index: 99;
            flex-wrap: wrap;
            justify-content: center;
            max-width: 85%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(8px);
            padding: 0.5rem 1.2rem;
            border-radius: 2rem;
        }

        .dot {
            width: 35px;
            height: 4px;
            background: rgba(255, 255, 255, 0.3);
            border-radius: 2px;
            cursor: pointer;
            transition: 0.3s;
        }

        .dot.active {
            background: #f4a261;
            width: 55px;
            box-shadow: 0 0 8px rgba(244, 162, 97, 0.5);
        }

        .counter {
            position: fixed;
            top: 20px;
            right: 20px;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(8px);
            padding: 8px 18px;
            border-radius: 30px;
            color: #f4a261;
            font-weight: 700;
            z-index: 100;
            font-size: 0.9rem;
            letter-spacing: 1px;
        }

        @media (max-width: 768px) {
            h1 { font-size: 2.5rem; }
            h2 { font-size: 1.6rem; }
            .slide-content { padding: 1.2rem; width: 95%; }
            .texto { font-size: 0.9rem; }
            .nav button { width: 45px; height: 45px; }
            .dot { width: 20px; }
            .dot.active { width: 35px; }
        }
    </style>
</head>
